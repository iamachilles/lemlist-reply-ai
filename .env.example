# ─── n8n ──────────────────────────────────────────────────────────────────
# Your n8n instance base URL (no trailing slash). Examples:
#   https://n8n.yourdomain.com
#   http://localhost:5678
N8N_BASE_URL=

# Personal API key from n8n: Settings → n8n API → Create API key
N8N_API_KEY=

# ─── Slack ────────────────────────────────────────────────────────────────
# Bot User OAuth Token from the Slack app you created from the manifest
# (api.slack.com/apps → your app → OAuth & Permissions → starts with xoxb-)
SLACK_BOT_TOKEN=

# Channel ID where AI-drafted replies will be posted
# (right-click channel in Slack → View channel details → bottom → starts with C)
SLACK_CHANNEL_ID=

# ─── OpenAI ───────────────────────────────────────────────────────────────
# API key from platform.openai.com/api-keys (starts with sk-)
OPENAI_API_KEY=

# ─── Lemlist ──────────────────────────────────────────────────────────────
# Lemlist → Settings → Integrations → API
LEMLIST_API_KEY=
LEMLIST_TEAM_NAME=

# ─── Company context (fed to the AI Agent) ────────────────────────────────
# Tip: if a value contains spaces, quotes, or apostrophes, wrap it in double quotes.
COMPANY_NAME=
# Multi-line allowed — what you do, for whom, value props, tone
COMPANY_CONTEXT=
DEFAULT_LANGUAGE=en
